{
  "outputDirectory": "dist",
  "framework": null,
  "buildCommand": null,
  "rewrites": [
    {
      "source": "/((?!_expo|assets|favicon\\.ico|metadata\\.json).*)",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/_expo/static/(.*)",
      "headers": [{ "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }]
    }
  ]
}